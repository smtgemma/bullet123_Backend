generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String          @id @default(uuid())
  fullName           String
  email              String          @unique
  password           String
  profilePic         String?
  passwordChangedAt  DateTime?
  isVerified         Boolean         @default(false)
  role               UserRole        @default(USER)
  isSubscribed       Boolean         @default(false)
  isBlocked          Boolean         @default(false)
  blockReason        String?
  planExpiration     DateTime?
  lastActiveAt       DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  stripeCustomerId   String?
  isDeleted          Boolean         @default(false)
  isBlocked          Boolean         @default(false)
  Notifications      Notification[]
  Profile            Profile?
  meetings           Meeting[]
  Subscription       Subscription[]
  Municipality       Municipality?   @relation(name: "MunicipalityUser")
  assignedProperties PropertyInfo[]
  tasks              Task[]
  sentMessages       Message[]       @relation("SentMessages")
  receivedMessages   Message[]       @relation("ReceivedMessages")
  signedDocuments    Document[]      @relation("SignatoryUser")
  uploadedPhotos     ProgressPhoto[] @relation("PhotoUploader")
  writtenReviews     Review[]        @relation("ReviewAuthor")
  receivedReviews    Review[]        @relation("ProfessionalReviews")
  successStories     SuccessStory[]  @relation("UserSuccessStories")
  questions          Question[]      @relation("UserQuestions")
  answers            Answer[]        @relation("UserAnswers")
  municipalityId     String?
  staffMunicipality  Municipality?   @relation(name: "StaffMunicipality", fields: [municipalityId], references: [id])

  @@map("users")
}

model FeaturedItem {
  id           String             @id @default(uuid())
  name         String             @unique
  key          String             @unique
  type         FeaturedType
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  planFeatures PlanFeaturedItem[]

  @@map("featured_items")
}

model PlanFeaturedItem {
  id             String       @id @default(uuid())
  planId         String
  featuredItemId String
  limit          Int?
  value          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  featuredItem   FeaturedItem @relation(fields: [featuredItemId], references: [id], onDelete: Cascade)
  plan           Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featuredItemId])
  @@map("plan_featured_items")
}

model Plan {
  id                String             @id @default(uuid())
  planName          String             @unique
  price             Float
  planType          PlanType           @default(BEGINNER)
  category          PlanCategory       @default(INDIVIDUAL)
  currency          String             @default("USD")
  interval          Interval           @default(month)
  intervalCount     Int                @default(1)
  productId         String             @unique
  priceId           String             @unique
  active            Boolean            @default(true)
  description       String
  discountType      DiscountType?
  discountValue     Float?
  discountedPrice   Float?
  discountStartDate DateTime?
  discountEndDate   DateTime?
  hasDiscount       Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  featuredItems     PlanFeaturedItem[]
  subscriptions     Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  planId               String
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  status               SubscriptionStatus @default(INCOMPLETE)
  cancelAtPeriodEnd    Boolean            @default(false)
  lastPaymentDate      DateTime?
  nextPaymentDate      DateTime?
  renewalAttempts      Int                @default(0)
  autoRenew            Boolean            @default(true)
  startDate            DateTime
  endDate              DateTime?
  amount               Float
  stripePaymentId      String?            @unique
  paymentStatus        PaymentStatus      @default(PENDING)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  plan                 Plan               @relation(fields: [planId], references: [id], onDelete: Cascade)
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  description String
  image       String
  category    String
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Profile {
  id        String    @id @default(uuid())
  userId    String    @unique
  birthDate DateTime?
  bio       String?
  location  String?
  website   String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpModel {
  id          String   @id @default(uuid())
  email       String
  code        String
  isVerified  Boolean  @default(false)
  generatedAt DateTime @default(now())
  expiresAt   DateTime
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id             String   @id @default(uuid())
  rating         Int
  comment        String
  reviewerId     String
  reviewer       User     @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)
  professionalId String
  professional   User     @relation("ProfessionalReviews", fields: [professionalId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Meeting {
  id              String        @id @default(uuid())
  userId          String
  organizationId  String?
  zoomMeetingId   String?       @unique
  joinUrl         String?
  startUrl        String?
  password        String?
  topic           String
  startTime       DateTime
  duration        Int
  timezone        String        @default("Asia/Dhaka")
  status          MeetingStatus @default(SCHEDULED)
  calendarEventId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meetings")
}

model Subscriber {
  id             String           @id @default(uuid())
  email          String           @unique
  status         SubscriberStatus @default(ACTIVE)
  accepted       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  blockedAt      DateTime?
  unsubscribedAt DateTime?
}

model Municipality {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(name: "MunicipalityUser", fields: [userId], references: [id], onDelete: Cascade)
  email  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties PropertyInfo[]
  staffs     User[]         @relation(name: "StaffMunicipality")

  @@map("municipalities")
}

model PropertyInfo {
  id              String          @id @default(cuid())
  municipalityId  String
  municipality    Municipality    @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  propertyAddress String
  parcelId        Int
  zone            String
  propertyType    String
  sqft            Float           @default(0)
  vacancyStatus   PropertyStatus  @default(VACANT)
  description     String?
  askingPrice     Float
  disposition     String
  images          String[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  assignedStaff   User[]
  tasks           Task[]
  budgets         Budget[]
  messages        Message[]
  documents       Document[]
  progressPhotos  ProgressPhoto[]
  timezone        String?
  closedAt        DateTime?

  @@index([municipalityId])
  @@map("property_infos")
}

model ProgressPhoto {
  id          String  @id @default(uuid())
  description String?
  url         String

  uploaderId String
  uploader   User   @relation("PhotoUploader", fields: [uploaderId], references: [id])

  propertyId String
  property   PropertyInfo @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("progress_photos")
}

model Document {
  id       String  @id @default(uuid())
  name     String
  type     String
  fileUrl  String
  fileSize String?

  isSigningRequired Boolean   @default(false)
  signatoryId       String?
  signatory         User?     @relation("SignatoryUser", fields: [signatoryId], references: [id])
  signedAt          DateTime?

  propertyId String
  property   PropertyInfo @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documents")
}

model Message {
  id      String @id @default(uuid())
  content String

  senderId String
  sender   User   @relation(name: "SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId String?
  receiver   User?   @relation(name: "ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  propertyId String?
  property   PropertyInfo? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("messages")
}

model Budget {
  id              String @id @default(uuid())
  description     String
  budgetedAmount  Float
  completedAmount Float  @default(0)

  propertyId String
  property   PropertyInfo @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("budgets")
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  file        String?
  status      TaskStatus @default(TODO)

  propertyId String
  property   PropertyInfo @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  assignees User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
}

enum MeetingStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum SubscriberStatus {
  ACTIVE
  BLOCKED
  UNSUBSCRIBED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELED
  REFUNDED
  FAILED
}

enum Status {
  PROCESSING
  COMPLETED
  FAILED
}

enum UserRole {
  BUYER
  SELLER
  MUNICIPALITY
  REALTOR
  CONTRACTOR
  INSPECTOR
  LENDER
  COMMUNITY_PARTNER
  USER
  ADMIN
  SUPER_ADMIN
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum FeaturedType {
  LIMIT
  STORAGE
  PROFILE
  GALLERY
  MARKETING
  BADGE
  SPOTLIGHT
  SUPPORT
  ANALYTICS
}

enum PlanType {
  BEGINNER
  PROFESSIONAL
  NON_PROFIT
  PROPERTY_OWNER
  MUNICIPALITY
}

enum Interval {
  month
  year
}

enum PlanCategory {
  INDIVIDUAL
  ORGANIZATION
}

model SuccessStory {
  id              String   @id @default(uuid())
  title           String
  propertyAddress String
  price           Float?
  description     String
  beforeImages    String[]
  afterImages     String[]
  userId          String
  user            User     @relation("UserSuccessStories", fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("success_stories")
}

model Question {
  id       String   @id @default(uuid())
  title    String
  details  String
  tags     String[]
  category String?
  views    Int      @default(0)
  upvotes  Int      @default(0)

  authorId String
  author   User   @relation("UserQuestions", fields: [authorId], references: [id], onDelete: Cascade)

  answers Answer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("questions")
}

model Answer {
  id         String  @id @default(uuid())
  content    String
  upvotes    Int     @default(0)
  isAccepted Boolean @default(false)

  authorId String
  author   User   @relation("UserAnswers", fields: [authorId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("answers")
}

enum PropertyStatus {
  VACANT
  UNDER_CONTRACT
  CLOSED
  COMPLETED
  CANCELLED
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  details   String
  createdAt DateTime @default(now())

  @@map("activity_logs")
}
