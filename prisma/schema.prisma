generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id                String         @id @default(uuid())
  fullName          String
  email             String         @unique
  password          String
  profilePic        String?
  passwordChangedAt DateTime?
  isVerified        Boolean        @default(false)
  role              UserRole       @default(USER)
  isSubscribed      Boolean        @default(false)
  planExpiration    DateTime?
  lastActiveAt      DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  stripeCustomerId  String?
  isDeleted         Boolean        @default(false)
  Notifications     Notification[]
  Profile           Profile?
  review            Review[]
  meetings          Meeting[]
  Subscription      Subscription[]
  Municipality      Municipality?  @relation(name: "MunicipalityUser")
  assignedProperties PropertyInfo[]
  teams             Team[]
  tasks             Task[]         @relation(name: "TaskAssignee")
  municipalityId    String?
  staffMunicipality Municipality?  @relation(name: "StaffMunicipality", fields: [municipalityId], references: [id])
  // Community Q&A
  questions         Question[]     @relation(name: "QuestionUser")
  answers           Answer[]       @relation(name: "AnswerUser")
  questionVotes     QuestionVote[] @relation(name: "QuestionVoteUser")
  answerVotes       AnswerVote[]   @relation(name: "AnswerVoteUser")
  // Settings
  settings          UserSettings?

  @@map("users")
}

model FeaturedItem {
  id           String             @id @default(uuid())
  name         String             @unique
  key          String             @unique
  type         FeaturedType
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  planFeatures PlanFeaturedItem[]

  @@map("featured_items")
}

model PlanFeaturedItem {
  id             String       @id @default(uuid())
  planId         String
  featuredItemId String
  limit          Int?
  value          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  featuredItem   FeaturedItem @relation(fields: [featuredItemId], references: [id], onDelete: Cascade)
  plan           Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featuredItemId])
  @@map("plan_featured_items")
}

model Plan {
  id                String             @id @default(uuid())
  planName          String             @unique
  price             Float
  planType          PlanType           @default(FREE)
  currency          String             @default("USD")
  interval          Interval           @default(month)
  intervalCount     Int                @default(1)
  productId         String             @unique
  priceId           String             @unique
  active            Boolean            @default(true)
  description       String
  discountType      DiscountType?
  discountValue     Float?
  discountedPrice   Float?
  discountStartDate DateTime?
  discountEndDate   DateTime?
  hasDiscount       Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  featuredItems     PlanFeaturedItem[]
  subscriptions     Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  planId               String
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  status               SubscriptionStatus @default(INCOMPLETE)
  cancelAtPeriodEnd    Boolean            @default(false)
  lastPaymentDate      DateTime?
  nextPaymentDate      DateTime?
  renewalAttempts      Int                @default(0)
  autoRenew            Boolean            @default(true)
  startDate            DateTime
  endDate              DateTime?
  amount               Float
  stripePaymentId      String?            @unique
  paymentStatus        PaymentStatus      @default(PENDING)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  plan                 Plan               @relation(fields: [planId], references: [id], onDelete: Cascade)
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  description String
  image       String
  category    String
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Profile {
  id               String    @id @default(uuid())
  userId           String    @unique
  birthDate        DateTime?
  bio              String?
  creativeFields   String[]
  age              Int?
  nationality      String?
  country          String?
  website          String?
  instagram        String?
  contactEmail     String?
  membershipStatus String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpModel {
  id          String   @id @default(uuid())
  email       String
  code        String
  isVerified  Boolean  @default(false)
  generatedAt DateTime @default(now())
  expiresAt   DateTime
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Meeting {
  id              String        @id @default(uuid())
  userId          String
  organizationId  String?
  zoomMeetingId   String?       @unique
  joinUrl         String?
  startUrl        String?
  password        String?
  topic           String
  startTime       DateTime
  duration        Int
  timezone        String        @default("Asia/Dhaka")
  status          MeetingStatus @default(SCHEDULED)
  calendarEventId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meetings")
}

model Subscriber {
  id             String           @id @default(uuid())
  email          String           @unique
  status         SubscriberStatus @default(ACTIVE)
  accepted       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  blockedAt      DateTime?
  unsubscribedAt DateTime?
}





model Municipality {
  id         String         @id @default(uuid())
  userId     String         @unique
  user       User           @relation(name: "MunicipalityUser", fields: [userId], references: [id], onDelete: Cascade)
  email      String

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  properties PropertyInfo[]
  teams      Team[]
  staffs     User[]         @relation(name: "StaffMunicipality")

  @@map("municipalities")
}

model PropertyInfo {
  id               String       @id @default(cuid())
  municipalityId   String
  municipality     Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  propertyAddress  String
  parcelId         Int
  zone             String
  propertyType     String
  vacancyStatus    String
  description      String?
  askingPrice      Float
  disposition      String
  images           String[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  assignedStaff    User[]
  teams            Team[]
  tasks            Task[]

  @@index([municipalityId])
  @@map("property_infos")
}

model Team {
  id             String       @id @default(cuid())
  name           String
  municipalityId String
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  members        User[]
  properties     PropertyInfo[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("teams")
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  file        String?
  status      TaskStatus   @default(TODO)
  
  propertyId  String
  property    PropertyInfo @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  assigneeId  String
  assignee    User         @relation(name: "TaskAssignee", fields: [assigneeId], references: [id])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}


enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
}

enum MeetingStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum SubscriberStatus {
  ACTIVE
  BLOCKED
  UNSUBSCRIBED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELED
  REFUNDED
  FAILED
}

enum Status {
  PROCESSING
  COMPLETED
  FAILED
}

enum UserRole {
  BUYER
  SELLER
  MUNICIPALITY
  REALTOR
  CONTRACTOR
  INSPECTOR
  LENDER
  COMMUNITY_PARTNER
  USER
  ADMIN
  SUPER_ADMIN
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum FeaturedType {
  LIMIT
  STORAGE
  PROFILE
  GALLERY
  MARKETING
  BADGE
  SPOTLIGHT
}

enum PlanType {
  FREE
  SILVER
  GOLD
}

enum Interval {
  month
  year
}

enum PlanCategory {
  ORGANIZATION
  ARTIST
}

enum StoryCategory {
  COMMUNITY_IMPACT
  AFFORDABLE_HOUSING
  COMMERCIAL
  RESIDENTIAL
  HISTORIC_PRESERVATION
  NEIGHBORHOOD_REVITALIZATION
}

// ── Community Q&A ──────────────────────────────────────────────────────────

model Question {
  id            String         @id @default(uuid())
  title         String
  details       String?
  tags          String[]
  userId        String
  user          User           @relation(name: "QuestionUser", fields: [userId], references: [id], onDelete: Cascade)
  votes         Int            @default(0)
  views         Int            @default(0)
  isAnswered    Boolean        @default(false)
  answers       Answer[]
  questionVotes QuestionVote[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("questions")
}

model Answer {
  id          String       @id @default(uuid())
  content     String
  questionId  String
  question    Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(name: "AnswerUser", fields: [userId], references: [id], onDelete: Cascade)
  votes       Int          @default(0)
  isAccepted  Boolean      @default(false)
  answerVotes AnswerVote[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("answers")
}

model QuestionVote {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(name: "QuestionVoteUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([questionId, userId])
  @@map("question_votes")
}

model AnswerVote {
  id        String   @id @default(uuid())
  answerId  String
  answer    Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(name: "AnswerVoteUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([answerId, userId])
  @@map("answer_votes")
}

// ── Success Stories ────────────────────────────────────────────────────────

model SuccessStory {
  id              String        @id @default(uuid())
  title           String
  category        StoryCategory
  location        String
  completedDate   DateTime
  beforeImage     String
  afterImage      String
  investment      Float
  duration        Int
  roi             Float
  storyText       String
  quote           String?
  quoteAuthor     String?
  quoteAuthorRole String?
  isFeatured      Boolean       @default(false)
  views           Int           @default(0)
  teamMembers     StoryTeamMember[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("success_stories")
}

model StoryTeamMember {
  id         String       @id @default(uuid())
  storyId    String
  story      SuccessStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  name       String
  role       String
  profilePic String?
  createdAt  DateTime     @default(now())

  @@map("story_team_members")
}

// ── User Settings ──────────────────────────────────────────────────────────

model UserSettings {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications   Boolean  @default(true)
  messageNotifications Boolean  @default(true)
  projectUpdates       Boolean  @default(true)
  profileVisibility    Boolean  @default(true)
  showContactInfo      Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("user_settings")
}
