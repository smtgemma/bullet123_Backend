generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String          @id @default(uuid())
  fullName           String
  email              String          @unique
  password           String
  profilePic         String?
  passwordChangedAt  DateTime?
  isVerified         Boolean         @default(false)
  role               UserRole        @default(USER)
  isSubscribed       Boolean         @default(false)
  planExpiration     DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  isDeleted          Boolean         @default(false)
  lastActiveAt       DateTime?
  stripeCustomerId   String?
  municipalityId     String?
  sellerId           String?
  Notifications      Notification[]
  Profile            Profile?
  receivedReviews    Review[]        @relation("ProfessionalReviews")
  writtenReviews     Review[]        @relation("ReviewAuthor")
  answers            Answer[]        @relation("UserAnswers")
  signedDocuments    Document[]      @relation("SignatoryUser")
  meetings           Meeting[]
  receivedMessages   Message[]       @relation("ReceivedMessages")
  sentMessages       Message[]       @relation("SentMessages")
  Municipality       Municipality?   @relation("MunicipalityUser")
  uploadedPhotos     ProgressPhoto[] @relation("PhotoUploader")
  questions          Question[]      @relation("UserQuestions")
  Seller             Seller?         @relation("SellerUser")
  Subscription       Subscription[]
  successStories     SuccessStory[]  @relation("UserSuccessStories")
  staffMunicipality  Municipality?   @relation("StaffMunicipality", fields: [municipalityId], references: [id])
  staffSeller        Seller?         @relation("StaffSeller", fields: [sellerId], references: [id])
  assignedProperties PropertyInfo[]  @relation("PropertyInfoToUser")
  tasks              Task[]          @relation("TaskToUser")

  @@map("users")
}

model FeaturedItem {
  id           String             @id @default(uuid())
  name         String             @unique
  key          String             @unique
  type         FeaturedType
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  planFeatures PlanFeaturedItem[]

  @@map("featured_items")
}

model PlanFeaturedItem {
  id             String       @id @default(uuid())
  planId         String
  featuredItemId String
  limit          Int?
  value          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  featuredItem   FeaturedItem @relation(fields: [featuredItemId], references: [id], onDelete: Cascade)
  plan           Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featuredItemId])
  @@map("plan_featured_items")
}

model Plan {
  id                String             @id @default(uuid())
  planName          String             @unique
  currency          String             @default("USD")
  interval          Interval           @default(month)
  intervalCount     Int                @default(1)
  productId         String             @unique
  priceId           String             @unique
  active            Boolean            @default(true)
  description       String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  discountEndDate   DateTime?
  discountStartDate DateTime?
  discountType      DiscountType?
  discountValue     Float?
  discountedPrice   Float?
  hasDiscount       Boolean            @default(false)
  planType          PlanType           @default(FREE)
  price             Float
  featuredItems     PlanFeaturedItem[]
  subscriptions     Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  planId               String
  startDate            DateTime
  endDate              DateTime?
  amount               Float
  stripePaymentId      String?            @unique
  paymentStatus        PaymentStatus      @default(PENDING)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  autoRenew            Boolean            @default(true)
  cancelAtPeriodEnd    Boolean            @default(false)
  currentPeriodEnd     DateTime
  currentPeriodStart   DateTime
  lastPaymentDate      DateTime?
  nextPaymentDate      DateTime?
  renewalAttempts      Int                @default(0)
  status               SubscriptionStatus @default(INCOMPLETE)
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  plan                 Plan               @relation(fields: [planId], references: [id], onDelete: Cascade)
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  description String
  image       String
  category    String
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Profile {
  id               String    @id @default(uuid())
  userId           String    @unique
  birthDate        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  age              Int?
  bio              String?
  location         String?  
  website          String?
  phone            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpModel {
  id          String   @id @default(uuid())
  email       String
  code        String
  isVerified  Boolean  @default(false)
  generatedAt DateTime @default(now())
  expiresAt   DateTime
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id             String   @id @default(uuid())
  rating         Int
  comment        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  professionalId String
  reviewerId     String
  professional   User     @relation("ProfessionalReviews", fields: [professionalId], references: [id], onDelete: Cascade)
  reviewer       User     @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)
}

model Meeting {
  id              String        @id @default(uuid())
  userId          String
  organizationId  String?
  zoomMeetingId   String?       @unique
  joinUrl         String?
  startUrl        String?
  password        String?
  topic           String
  startTime       DateTime
  duration        Int
  timezone        String        @default("Asia/Dhaka")
  status          MeetingStatus @default(SCHEDULED)
  calendarEventId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meetings")
}

model Subscriber {
  id             String           @id @default(uuid())
  email          String           @unique
  status         SubscriberStatus @default(ACTIVE)
  accepted       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  blockedAt      DateTime?
  unsubscribedAt DateTime?
}

model Municipality {
  id         String         @id @default(uuid())
  userId     String         @unique
  email      String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation("MunicipalityUser", fields: [userId], references: [id], onDelete: Cascade)
  properties PropertyInfo[]
  staffs     User[]         @relation("StaffMunicipality")

  @@map("municipalities")
}

model Seller {
  id          String         @id @default(uuid())
  userId      String         @unique
  email       String
  bio         String?
  location    String?
  phoneNumber String?
  website     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  properties  PropertyInfo[]
  user        User           @relation("SellerUser", fields: [userId], references: [id], onDelete: Cascade)
  staffs      User[]         @relation("StaffSeller")

  @@map("sellers")
}

model PropertyInfo {
  id              String          @id @default(cuid())
  municipalityId  String?
  propertyAddress String
  parcelId        Int
  zone            String
  propertyType    String
  vacancyStatus   String
  description     String?
  askingPrice     Float
  disposition     String
  images          String[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  sellerId        String?
  budgets         Budget[]
  documents       Document[]
  messages        Message[]
  progressPhotos  ProgressPhoto[]
  municipality    Municipality?   @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  seller          Seller?         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  tasks           Task[]
  assignedStaff   User[]          @relation("PropertyInfoToUser")

  @@index([municipalityId])
  @@map("property_infos")
}

model ProgressPhoto {
  id          String       @id @default(uuid())
  description String?
  url         String
  uploaderId  String
  propertyId  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  property    PropertyInfo @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  uploader    User         @relation("PhotoUploader", fields: [uploaderId], references: [id])

  @@map("progress_photos")
}

model Document {
  id                String       @id @default(uuid())
  name              String
  type              String
  fileUrl           String
  fileSize          String?
  isSigningRequired Boolean      @default(false)
  signatoryId       String?
  signedAt          DateTime?
  propertyId        String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  property          PropertyInfo @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  signatory         User?        @relation("SignatoryUser", fields: [signatoryId], references: [id])

  @@map("documents")
}

model Message {
  id         String        @id @default(uuid())
  content    String
  senderId   String
  propertyId String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  isRead     Boolean       @default(false)
  receiverId String?
  property   PropertyInfo? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  receiver   User?         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Budget {
  id              String       @id @default(uuid())
  description     String
  budgetedAmount  Float
  completedAmount Float        @default(0)
  propertyId      String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  property        PropertyInfo @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("budgets")
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  file        String?
  status      TaskStatus   @default(TODO)
  propertyId  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  property    PropertyInfo @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  assignees   User[]       @relation("TaskToUser")

  @@map("tasks")
}

model SuccessStory {
  id              String   @id @default(uuid())
  title           String
  propertyAddress String
  price           Float?
  description     String
  beforeImages    String[]
  afterImages     String[]
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation("UserSuccessStories", fields: [userId], references: [id], onDelete: Cascade)

  @@map("success_stories")
}

model Question {
  id        String   @id @default(uuid())
  title     String
  details   String
  tags      String[]
  category  String?
  views     Int      @default(0)
  upvotes   Int      @default(0)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  answers   Answer[]
  author    User     @relation("UserQuestions", fields: [authorId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model Answer {
  id         String   @id @default(uuid())
  content    String
  upvotes    Int      @default(0)
  isAccepted Boolean  @default(false)
  authorId   String
  questionId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation("UserAnswers", fields: [authorId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answers")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
}

enum MeetingStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum SubscriberStatus {
  ACTIVE
  BLOCKED
  UNSUBSCRIBED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELED
  REFUNDED
  FAILED
}

enum Status {
  PROCESSING
  COMPLETED
  FAILED
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  BUYER
  SELLER
  MUNICIPALITY
  REALTOR
  CONTRACTOR
  INSPECTOR
  LENDER
  COMMUNITY_PARTNER
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum FeaturedType {
  LIMIT
  STORAGE
  PROFILE
  GALLERY
  MARKETING
  BADGE
  SPOTLIGHT
}

enum PlanType {
  FREE
  SILVER
  GOLD
}

enum Interval {
  month
  year
}

enum PlanCategory {
  ORGANIZATION
  ARTIST
}
